{
  "name": "hotkey-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "openapi2ts",
    "openapi:generate:local": "HOTKEY_OPENAPI_SCHEMA=../hotkey-server/docs/openapi/swagger.json openapi2ts",
    "test": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "e2e:auth": "agent-browser --session-name hotkey-auth",
    "e2e:chat": "agent-browser chat"
  },
  "dependencies": {
